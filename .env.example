# =============================================================================
# Migrant Archive — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
# =============================================================================

# --- YouTube Channel (required) ---
# YouTube channel URL to process. Content is primarily Spanish.
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@FILMIG

# --- Gemini API (required for embeddings + LLM) ---
# Get your key at: https://aistudio.google.com/apikey
# Free tier is generous — enough for this entire project.
GEMINI_API_KEY=your-gemini-api-key-here

# --- HuggingFace Token (optional — only needed for WhisperX speaker diarisation) ---
# The current faster-whisper pipeline does NOT use speaker diarisation, so
# this token is not required. Uncomment and fill in only if you switch to
# WhisperX for speaker-labelled transcripts.
# Get your token at: https://huggingface.co/settings/tokens (read-only is enough)
# Required by WhisperX for pyannote/speaker-diarization-3.1 model.
# You must also accept the terms at: https://hf.co/pyannote/speaker-diarization-3.1
# HF_TOKEN=hf_your-huggingface-token-here

# --- OpenAI API (optional — only if using OpenAI embeddings or LLM) ---
# Get your key at: https://platform.openai.com/api-keys
# Not needed if using Gemini (default).
# OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Embedding Provider (optional) ---
# Which embedding provider to use. Options: gemini | bge-m3 | openai
# Default: gemini
# EMBEDDING_PROVIDER=gemini

# --- LLM Provider (optional) ---
# Which LLM to use for RAG answers. Options: gemini | openai
# Default: gemini (uses GEMINI_API_KEY)
# LLM_PROVIDER=gemini

# --- LLM Model (optional) ---
# Specific model ID. Defaults shown below.
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-4o-mini

# --- ChromaDB (optional) ---
# Path to persist the vector database. Default: data/chroma
# CHROMA_PERSIST_DIR=data/chroma

# --- LangSmith (optional — for tracing/evaluation) ---
# https://smith.langchain.com/
# Set LANGSMITH_TRACING=true to send traces. Disabled by default so contributors
# do not accidentally send local runs to the project.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your-langsmith-key-here
LANGSMITH_PROJECT=migrant-archive
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
