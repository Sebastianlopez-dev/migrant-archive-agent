# --- Dev tool dotfiles: catch-all (Claude, OpenCode, ATL, etc.) ---
.*
# --- Explicit exceptions: dotfiles that MUST be tracked ---
!.env.example

# --- Python ---
__pycache__/
*.pyc
*.pyo

# --- ML models (downloaded at runtime) ---
models/

# --- Generated data (rebuilt on demand) ---
data/audio/
data/chroma/

# --- Frontend ---
frontend/node_modules/
frontend/dist/
